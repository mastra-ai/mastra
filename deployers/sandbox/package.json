{
  "name": "@mastra/deployer-sandbox",
  "version": "0.1.0-alpha.0",
  "description": "Deploy a Mastra server into any workspace sandbox that supports networking and get a live public URL",
  "type": "module",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "browser": null,
      "import": {
        "types": "./dist/client/index.d.ts",
        "default": "./dist/client/index.js"
      },
      "require": {
        "types": "./dist/client/index.d.ts",
        "default": "./dist/client/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown --silent --config tsdown.config.ts",
    "build:watch": "tsdown --watch --silent --config tsdown.config.ts",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@mastra/deployer": "workspace:^",
    "fs-extra": "^11.3.5"
  },
  "devDependencies": {
    "@internal/lint": "workspace:*",
    "@internal/playground": "workspace:*",
    "@internal/types-builder": "workspace:*",
    "@mastra/core": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "22.20.1",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "eslint": "^10.4.1",
    "tsdown": "0.22.9",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "homepage": "https://mastra.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastra-ai/mastra.git",
    "directory": "deployers/sandbox"
  },
  "bugs": {
    "url": "https://github.com/mastra-ai/mastra/issues"
  },
  "peerDependencies": {
    "@mastra/core": ">=1.52.0-0 <2.0.0-0"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
