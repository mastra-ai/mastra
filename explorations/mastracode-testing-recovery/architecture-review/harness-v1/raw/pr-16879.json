        }
      ],
      "committedDate": "2026-05-20T13:23:34Z",
      "messageBody": "Add the Harness v1 storage contract for session records, leases, and attachments.\n\nWire the in-memory implementation into InMemoryStore and the composite storage domains so v1 sessions have a standard development/test backing store.",
      "messageHeadline": "feat(core): add harness storage domain",
      "oid": "300dcc546416f329b9c1dec98c7b4e831a9ab43d"
    },
    {
      "authoredDate": "2026-05-20T16:27:58Z",
      "authors": [
        {
          "email": "mbenhamd@gmail.com",
          "id": "MDQ6VXNlcjE2NzIwNDY3",
          "login": "mbenhamd",
          "name": "Mohamed BEN HAMDOUNE"
        }
      ],
      "committedDate": "2026-05-20T16:27:58Z",
      "messageBody": "Extracts the forked Harness v1 registry slice into @mastra/core/harness/v1, including durable session resolution, leases, lifecycle, model discovery, thread utilities, workspace provider registration, and focused regression coverage.",
      "messageHeadline": "feat(core): add harness v1 registry",
      "oid": "df3ee880910eface225190df96d263393fae72b7"
    },
    {
      "authoredDate": "2026-05-20T16:48:39Z",
      "authors": [
        {
          "email": "mbenhamd@gmail.com",
          "id": "MDQ6VXNlcjE2NzIwNDY3",
          "login": "mbenhamd",
          "name": "Mohamed BEN HAMDOUNE"
        }
      ],
      "committedDate": "2026-05-20T16:48:39Z",
      "messageBody": "Ports the forked Session state, mode, and model-selection layer into the stacked Harness v1 implementation. Adds CAS-backed persistence, state change events, model override events, and regression coverage for record version and lease-renewal behavior.",
      "messageHeadline": "feat(core): add harness v1 session state",
      "oid": "d3c99f275b2022eb597f0c9abb3eeb17c17bf12e"
    },
    {
      "authoredDate": "2026-05-20T17:31:44Z",
      "authors": [
        {
          "email": "mbenhamd@gmail.com",
          "id": "MDQ6VXNlcjE2NzIwNDY3",
          "login": "mbenhamd",
          "name": "Mohamed BEN HAMDOUNE"
        }
      ],
      "committedDate": "2026-05-20T17:31:44Z",
      "messageBody": "Add the next Harness v1 Session slice: status accessors, idle waiters, token usage reads, and listMessages history readback.\n\nShare the legacy-compatible message converter with v1 and cover signal rows, system reminders, completed tool calls without result payloads, no-memory behavior, and resource-scoped reads.",
      "messageHeadline": "feat(core): add harness v1 session accessors",
      "oid": "2156509669559bfe1093668dc72757a6f5936f1c"
    },
    {
      "authoredDate": "2026-05-20T18:11:54Z",
      "authors": [
        {
          "email": "mbenhamd@gmail.com",
          "id": "MDQ6VXNlcjE2NzIwNDY3",
          "login": "mbenhamd",
          "name": "Mohamed BEN HAMDOUNE"
        }
      ],
      "committedDate": "2026-05-20T18:11:54Z",
      "messageBody": "Add thread-stream runtime lookup and waiter APIs for signal-started runs so Harness v1 can recover the MastraModelOutput after Agent.sendSignal reserves a run.\n\nWaiters now resolve on registration and reject on abort or idle wake setup failure, with focused coverage for the timing windows.",
      "messageHeadline": "feat(core): expose agent thread run outputs",
      "oid": "5ab333bd203ddbea5be56c3bee2181141e38b197"
    },
    {
      "authoredDate": "2026-05-21T00:18:59Z",
      "authors": [
        {
          "email": "mbenhamd@gmail.com",
          "id": "MDQ6VXNlcjE2NzIwNDY3",
          "login": "mbenhamd",
          "name": "Mohamed BEN HAMDOUNE"
        }
      ],
      "committedDate": "2026-05-21T00:18:59Z",
      "messageBody": "Sync the current Harness v1 runtime and storage foundation from the latest fork tree, including Session lifecycle, message admission, queueing, built-in HITL/task tools, wakeup worker support, and expanded in-memory harness storage coverage.\n\nAdapt the runtime to the official stacked base by using the agent run-output waiter, preserving public v1 exports, guarding workspace/session lifecycle races, and keeping Mastra worker shutdown behavior deterministic.",
      "messageHeadline": "feat(core): sync latest harness v1 foundation",
      "oid": "0454bfd03be1b1e79fd167af682c6d5a92948272"
    }
  ],
