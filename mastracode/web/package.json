{
  "name": "mastracode-web",
  "version": "0.1.0",
  "description": "MastraCode web surface: API routes, deployable Mastra entry, and the SPA UI. Standalone pnpm project consuming monorepo packages via link: — run pnpm install at the monorepo root first; `pnpm prebuild` builds the linked packages (web:build / web:ui:build run it automatically).",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit && pnpm check:ui",
    "check:ui": "tsc --noEmit -p src/web/ui/tsconfig.json",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "prebuild": "cd ../.. && pnpm turbo build --filter ./mastracode/sdk --filter ./mastracode/factory --filter ./packages/playground-ui --filter ./client-sdks/client-js --filter ./client-sdks/react --filter ./stores/libsql --filter ./stores/pg --filter ./auth/better-auth --filter ./auth/workos --filter ./auth/studio --filter ./server-adapters/hono --filter ./workspaces/platform-workspace --filter ./workspaces/railway --filter ./pubsub/redis-streams --filter ./packages/cli",
    "web:dev": "concurrently --kill-others-on-fail --names server,ui \"PORT=4111 MASTRA_SKIP_PEERDEP_CHECK=1 varlock run -- mastra dev --dir src/mastra\" \"vite --config src/web/vite.config.ts\"",
    "web:dev:github": "pnpm db:up && pnpm web:dev",
    "web:ui:build": "pnpm run prebuild && node scripts/copy-factory-skills.mjs && vite --config src/web/vite.config.ts build",
    "web:build": "pnpm run web:ui:build && node scripts/monorepo-deps.mjs run -- mastra build --dir src/mastra",
    "web:deploy": "pnpm run web:build && node scripts/validate-output.mjs && mastra deploy --skip-build",
    "deps:pin": "node scripts/monorepo-deps.mjs pin",
    "deps:link": "node scripts/monorepo-deps.mjs link",
    "web:start": "varlock run -- mastra start",
    "web:test": "vitest run --config e2e/web/vitest.config.ts",
    "web:ui:test": "vitest run --config e2e/web-ui/vitest.config.ts",
    "test": "vitest run && vitest run --config e2e/web/vitest.config.ts && vitest run --config e2e/web-ui/vitest.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@duckdb/node-bindings": "1.5.4-r.1",
    "@fontsource-variable/mona-sans": "5.3.0",
    "@mastra/auth-better-auth": "link:../../auth/better-auth",
    "@mastra/auth-studio": "link:../../auth/studio",
    "@mastra/auth-workos": "link:../../auth/workos",
    "@mastra/client-js": "link:../../client-sdks/client-js",
    "@mastra/code-sdk": "link:../sdk",
    "@mastra/core": "link:../../packages/core",
    "@mastra/factory": "link:../factory",
    "@mastra/hono": "link:../../server-adapters/hono",
    "@mastra/libsql": "link:../../stores/libsql",
    "@mastra/pg": "link:../../stores/pg",
    "@mastra/platform-workspace": "link:../../workspaces/platform-workspace",
    "@mastra/playground-ui": "link:../../packages/playground-ui",
    "@mastra/railway": "link:../../workspaces/railway",
    "@mastra/react": "link:../../client-sdks/react",
    "@mastra/redis-streams": "link:../../pubsub/redis-streams",
    "@octokit/auth-app": "^8.0.0",
    "@octokit/rest": "^22.0.1",
    "@tanstack/react-query": "^5.90.21",
    "@workos-inc/node": "8.8.0",
    "date-fns": "^4.4.0",
    "debug": "^4.4.3",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.12.8",
    "lucide-react": "^0.474.0",
    "marked": "^15.0.0",
    "pg": "^8.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "^7.13.1",
    "shiki": "^1.29.2",
    "supports-color": "^10.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.86",
    "@copilotkit/aimock": "^1.29.0",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "22.20.1",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "concurrently": "^9.1.2",
    "jsdom": "^26.1.0",
    "mastra": "link:../../packages/cli",
    "msw": "^2.12.11",
    "react-grab": "^0.1.37",
    "tailwindcss": "4.2.2",
    "tsx": "^4.23.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.2",
    "varlock": "^1.9.0",
    "vite": "^6.0.0",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
