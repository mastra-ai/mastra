{
  "name": "mastracode-web",
  "version": "0.1.0",
  "description": "MastraCode web surface: API routes, tenant server, deployable Mastra entry, and the SPA UI. Standalone pnpm project consuming monorepo packages via link: — run pnpm install at the monorepo root first; `pnpm prebuild` builds the linked packages (web:build / web:ui:build run it automatically).",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit && pnpm check:ui",
    "check:ui": "tsc --noEmit -p src/web/ui/tsconfig.json",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "prebuild": "cd ../.. && pnpm turbo build --filter ./mastracode/sdk --filter ./packages/playground-ui --filter ./client-sdks/client-js --filter ./client-sdks/react --filter ./stores/libsql --filter ./auth/workos --filter ./server-adapters/hono --filter ./workspaces/railway --filter ./packages/cli",
    "web:dev": "concurrently --kill-others-on-fail --names server,ui \"PORT=4111 MASTRA_SKIP_PEERDEP_CHECK=1 varlock run -- mastra dev --dir src/mastra\" \"vite --config src/web/vite.config.ts\"",
    "web:dev:github": "pnpm db:up && pnpm web:dev",
    "web:ui:build": "pnpm run prebuild && vite --config src/web/vite.config.ts build",
    "web:build": "pnpm run web:ui:build && MASTRA_SKIP_PEERDEP_CHECK=1 mastra build --dir src/mastra",
    "web:start": "varlock run -- mastra start",
    "web:test": "vitest run --config e2e/web/vitest.config.ts",
    "web:ui:test": "vitest run --config e2e/web-ui/vitest.config.ts",
    "test": "vitest run --config e2e/web/vitest.config.ts && vitest run --config e2e/web-ui/vitest.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@mastra/auth-workos": "latest",
    "@mastra/client-js": "latest",
    "@mastra/code-sdk": "0.0.0-mastracode-cloud-20260706153555",
    "@mastra/core": "0.0.0-mastracode-cloud-20260706153555",
    "@mastra/hono": "latest",
    "@mastra/libsql": "0.0.0-mastracode-cloud-20260706153555",
    "@mastra/playground-ui": "latest",
    "@mastra/railway": "latest",
    "@mastra/react": "latest",
    "@octokit/auth-app": "^8.0.0",
    "@octokit/rest": "^22.0.1",
    "@tanstack/react-query": "^5.90.21",
    "@tursodatabase/api": "2.0.4",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.12.8",
    "lucide-react": "^0.474.0",
    "marked": "^15.0.0",
    "pg": "^8.21.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "^7.13.1",
    "shiki": "^1.29.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "@copilotkit/aimock": "^1.29.0",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "22.19.21",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "concurrently": "^9.1.2",
    "jsdom": "^26.1.0",
    "mastra": "latest",
    "msw": "^2.12.11",
    "tailwindcss": "4.2.2",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "varlock": "^1.9.0",
    "vite": "^6.0.0",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
