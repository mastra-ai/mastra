# Mastra Gateway — single key proxies to OpenAI, Anthropic, Google, etc.
# https://mastra.ai/docs/models/gateways/mastra
MASTRA_GATEWAY_API_KEY=

# Turso (libSQL) — used for observability + observational memory
# Example: libsql://my-db.turso.io
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Run the browser with a visible UI (false) or headless (true, default).
# Useful to flip to false locally to watch the agent click around.
BROWSER_HEADLESS=true

# Optional: connect to a hosted Chrome/Browserbase/Browserless instance instead of launching local Chromium.
# Recommended for server deployments where the runtime image does not include browser system libraries.
# BROWSER_CDP_URL=
