# Mastra Gateway — single key proxies to OpenAI, Anthropic, Google, etc.
# https://mastra.ai/docs/models/gateways/mastra
MASTRA_GATEWAY_API_KEY=

# Turso (libSQL) — used for observability + observational memory
# Example: libsql://my-db.turso.io
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Run the browser with a visible UI (false) or headless (true, default).
# Useful to flip to false locally to watch the agent click around.
BROWSER_HEADLESS=true

# Recommended for server deployments: connect to a hosted Chrome/Browserbase/Browserless instance.
# Local Chromium is disabled by default because many server images do not include Chrome system libraries.
# BROWSER_CDP_URL=

# Optional local-only escape hatch: launch the installed local Chromium when BROWSER_CDP_URL is not set.
# Do not enable this in server deployments unless the runtime image includes Chromium system libraries.
# BROWSER_ALLOW_LOCAL_CHROMIUM=false
