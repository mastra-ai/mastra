# Sendly API key — get yours at https://sendly.live/settings/api-keys
# Use sk_test_ prefix for sandbox (no real SMS sent, no credits used)
# Use sk_live_ prefix for production
SENDLY_API_KEY=sk_test_v1_your_key_here

# OpenAI API key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
