# Vercel builds the docs site with `npm install` in this directory, and npm
# treats peer conflicts as hard errors (ERESOLVE). @mastra/docusaurus-plugin-algolia
# peers react ^19 / lucide-react ^1.8.0, which are stricter than this site's pins
# (react 18, lucide-react 0.x); the plugin works against these versions at runtime,
# and pnpm already installs fine with a warning. Accept the mismatch so the npm
# install on Vercel resolves the same way.
legacy-peer-deps=true
