{
  "name": "@mastra/react",
  "version": "0.2.9",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastra-ai/mastra.git",
    "directory": "client-sdks/react"
  },
  "bugs": {
    "url": "https://github.com/mastra-ai/mastra/issues"
  },
  "homepage": "https://mastra.ai",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/react.css"
  },
  "scripts": {
    "lint": "eslint .",
    "build": "echo 'Use turbo to run build'",
    "build:js": "tsup --config tsup.config.ts",
    "build:css": "tailwindcss -i src/ui/index.css -o dist/react.css",
    "dev": "tsup --config tsup.config.ts --watch",
    "test": "vitest",
    "test:unit": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@mastra/client-js": "workspace:*",
    "@lukeed/uuid": "^2.0.1",
    "@radix-ui/react-tooltip": "^1.2.7",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "lucide-react": "^0.522.0",
    "shiki": "^1.29.2",
    "tailwind-merge": "^3.4.1"
  },
  "peerDependencies": {
    "@mastra/core": ">=1.8.0-0 <2.0.0-0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@ai-sdk/react": "^2.0.57",
    "@assistant-ui/react": "^0.12.10",
    "@internal/lint": "workspace:*",
    "@mastra/core": "workspace:*",
    "@internal/types-builder": "workspace:*",
    "@storybook/react-vite": "^9.1.16",
    "@tailwindcss/cli": "^4",
    "@tailwindcss/vite": "^4.1.17",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "eslint": "^9.37.0",
    "eslint-plugin-storybook": "^10.1.11",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "storybook": "^9.1.10",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "typescript": "catalog:",
    "vite": "^7.3.1",
    "vitest": "catalog:",
    "zod": "^3.25.0"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
