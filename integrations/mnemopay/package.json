{
  "name": "@mastra/mnemopay",
  "version": "0.0.1-alpha.0",
  "description": "MnemoPay integration for Mastra — economic memory for AI commerce agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:lib": "tsup --silent --config tsup.config.ts",
    "build:watch": "pnpm build:lib --watch",
    "lint": "eslint ."
  },
  "keywords": [
    "mastra",
    "mnemopay",
    "economic-memory",
    "ai-payments",
    "commerce-agents",
    "reputation"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastra-ai/mastra.git",
    "directory": "integrations/mnemopay"
  },
  "bugs": {
    "url": "https://github.com/mastra-ai/mastra/issues"
  },
  "homepage": "https://mastra.ai",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@mastra/core": "workspace:*",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@mnemopay/sdk": ">=0.1.0"
  },
  "devDependencies": {
    "@internal/lint": "workspace:*",
    "@mnemopay/sdk": "*",
    "tsup": "^8.5.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
