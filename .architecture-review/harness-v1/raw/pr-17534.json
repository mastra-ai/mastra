        }
      ],
      "committedDate": "2026-06-03T13:30:04Z",
      "messageBody": "Add v1 harness tool composition, permission and subagent config plumbing, and canonical workspace Skill support for session skill APIs. This removes the separate HarnessSkill shape so configured skills use the same Skill/SkillMetadata model as workspace-discovered skills.\n\nCo-Authored-By: Mastra Code (openai/gpt-5.5) <noreply@mastra.ai>",
      "messageHeadline": "feat(core): add v1 harness tools and canonical skills",
      "oid": "ccbd9ac9e3b39475af1e28dff675673334637389"
    },
    {
      "authoredDate": "2026-06-03T09:21:30Z",
      "authors": [
        {
          "email": "ward@coding-tech.com",
          "id": "MDQ6VXNlcjExMjA5MjY=",
          "login": "wardpeet",
          "name": "wardpeet"
        },
        {
          "email": "noreply@mastra.ai",
          "id": "",
          "login": "",
          "name": "Mastra Code (openai/gpt-5.5)"
        }
      ],
      "committedDate": "2026-06-03T13:30:04Z",
      "messageBody": "Do not forward legacy MastraCode subagent definitions into the new Harness v1 subagent registry yet. The legacy shape does not declare agentId and subagents are still executed by HarnessCompat/v0 until the v1 subagent runtime is implemented.\n\nCo-Authored-By: Mastra Code (openai/gpt-5.5) <noreply@mastra.ai>",
      "messageHeadline": "fix(mastracode): keep v0 subagents out of harness v1",
      "oid": "44716a4444915e319b55a7d9d77abf02884485e1"
    },
    {
      "authoredDate": "2026-06-03T10:05:29Z",
