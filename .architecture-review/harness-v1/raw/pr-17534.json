        }
      ],
      "committedDate": "2026-06-03T13:30:02Z",
      "messageBody": "Move session-derived model fields out of Mastra Code harness state and compose them from Harness v1 sessions through HarnessCompat. This keeps app-level config in harness state while session-owned model values stay with the session.\\n\\nCo-Authored-By: Mastra Code (openai/gpt-5.5) <noreply@mastra.ai>",
      "messageHeadline": "feat(core): compose session state in harness compat",
      "oid": "85bce1b05b6f60cc6f53e74a3d0121721956a0cf"
    },
