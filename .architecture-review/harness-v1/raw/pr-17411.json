          "id": "",
          "login": "",
          "name": "Mastra Code (zai-coding-plan/glm-5.1)"
        }
      ],
      "committedDate": "2026-06-02T13:05:45Z",
      "messageBody": "Session now owns workspace resolution with lazy caching, removing the\nworkspaceFn/setWorkspace mutation callback pattern from Harness.\n\nCo-Authored-By: Mastra Code (zai-coding-plan/glm-5.1) <noreply@mastra.ai>",
      "messageHeadline": "refactor(core): simplify v1 session workspace to single DynamicArgument",
      "oid": "60c0f82d2c3160f5193571e4aa49c4cb628afbe5"
    },
