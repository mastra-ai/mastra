{
  "name": "@mastra/mssql",
  "version": "1.4.1",
  "description": "MSSQL provider for Mastra - db storage capabilities",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:lib": "tsdown --silent --config tsdown.config.ts",
    "prepack": "tsx ../../scripts/generate-package-docs.ts",
    "build:watch": "tsdown --watch --silent --config tsdown.config.ts",
    "pretest": "docker compose up -d --wait",
    "test": "vitest run",
    "pretest:watch": "docker compose up -d",
    "test:watch": "vitest watch",
    "posttest:watch": "docker compose down -v",
    "lint": "eslint ."
  },
  "license": "Apache-2.0",
  "dependencies": {
    "mssql": "^12.5.5"
  },
  "devDependencies": {
    "@internal/lint": "workspace:*",
    "@internal/storage-test-utils": "workspace:*",
    "@internal/types-builder": "workspace:*",
    "@mastra/core": "workspace:*",
    "@types/mssql": "^9.1.11",
    "@types/node": "22.20.1",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "eslint": "^10.7.0",
    "tsdown": "0.22.9",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@mastra/core": ">=1.0.0-0 <2.0.0-0"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "homepage": "https://mastra.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastra-ai/mastra.git",
    "directory": "stores/mssql"
  },
  "bugs": {
    "url": "https://github.com/mastra-ai/mastra/issues"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
