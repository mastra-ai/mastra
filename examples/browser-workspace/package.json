{
  "name": "examples-browser-workspace",
  "type": "module",
  "private": true,
  "description": "Example: Mastra agent with browser capability via workspace CLI",
  "version": "0.0.1",
  "dependencies": {
    "@ai-sdk/openai": "npm:@ai-sdk/openai@2.0.15",
    "@hono/node-ws": "^1.3.0",
    "@mastra/core": "latest",
    "@mastra/memory": "latest",
    "@mastra/libsql": "latest",
    "@mastra/agent-browser": "latest",
    "@mastra/stagehand": "latest",
    "@mastra/browser-viewer": "latest",
    "mastra": "latest",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "@mastra/core": "link:../../packages/core",
      "@mastra/memory": "link:../../packages/memory",
      "@mastra/libsql": "link:../../stores/libsql",
      "@mastra/agent-browser": "link:../../browser/agent-browser",
      "@mastra/stagehand": "link:../../browser/stagehand",
      "@mastra/browser-viewer": "link:../../browser/browser-viewer",
      "mastra": "link:../../packages/cli"
    }
  },
  "scripts": {
    "dev": "mastra dev",
    "start": "npx tsx src/index.ts"
  },
  "license": "Apache-2.0"
}