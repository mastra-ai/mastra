{
  "name": "examples-agentfs-workspace",
  "type": "module",
  "private": true,
  "description": "Example demonstrating AgentFS (Turso/SQLite-backed) filesystem with the Workspace API",
  "version": "0.0.1",
  "dependencies": {
    "@ai-sdk/openai": "^3.0.0",
    "@mastra/agentfs": "latest",
    "@mastra/core": "latest",
    "ai": "^6.0.1",
    "zod": "^3"
  },
  "pnpm": {
    "overrides": {
      "@mastra/core": "link:../../packages/core",
      "@mastra/agentfs": "link:../../workspaces/agentfs"
    }
  },
  "scripts": {
    "demo": "tsx src/demo/index.ts",
    "demo:filesystem": "tsx src/demo/index.ts --type filesystem",
    "demo:agents": "tsx src/demo/index.ts --type agents"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
