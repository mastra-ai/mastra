# Set to "workos" to enable WorkOS SSO (requires WORKOS_API_KEY + WORKOS_CLIENT_ID).
# Leave unset to run with no authentication.
AUTH_PROVIDER=

# WorkOS (only needed when AUTH_PROVIDER=workos)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=http://localhost:4111/api/auth/callback

# Required to unlock the Agent Builder EE features
MASTRA_EE_LICENSE=
