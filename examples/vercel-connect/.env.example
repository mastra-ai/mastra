# OpenAI key for the agent's LLM
OPENAI_API_KEY=sk-...

# Vercel Connect connector names (created via `vercel connect create`)
VERCEL_CONNECT_SLACK_CONNECTOR=slack/my-slack
VERCEL_CONNECT_GITHUB_CONNECTOR=github/my-github

# --- Authentication (pick one) ---

# Option A: Vercel OIDC (automatic on Vercel deployments)
# Run `vercel link && vercel env pull` locally to get a dev token in .env.local

# Option B: Vercel access token (for non-Vercel environments)
# VERCEL_TOKEN=your-vercel-access-token
