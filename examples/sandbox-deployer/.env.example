# Model provider key (forwarded into the sandbox so the agent can generate)
OPENAI_API_KEY=

# Pick a provider (default: vercel)
# SANDBOX_PROVIDER=vercel|e2b|daytona

# Vercel Sandbox auth — either:
#   1. Run `vercel link && vercel env pull` to get a VERCEL_OIDC_TOKEN in .env.local, or
#   2. Set an access token + team + project explicitly:
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=
# VERCEL_PROJECT_ID=

# E2B Sandbox auth (https://e2b.dev/dashboard)
# E2B_API_KEY=

# Daytona Sandbox auth (https://app.daytona.io)
# DAYTONA_API_KEY=
# DAYTONA_API_URL=
