{
  "name": "examples-sandbox-deployer",
  "type": "module",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build:linked-workspace-deps": "turbo --cwd ../.. build --filter mastra --filter @mastra/deployer-sandbox --filter @mastra/vercel --filter @mastra/e2b --filter @mastra/daytona",
    "build": "pnpm build:linked-workspace-deps && pnpm mastra:build",
    "mastra:build": "node ../../packages/cli/dist/index.js build",
    "mastra:dev": "node ../../packages/cli/dist/index.js dev",
    "stop": "node --env-file=.env.local --import tsx scripts/stop.ts",
    "destroy": "node --env-file=.env.local --import tsx scripts/destroy.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mastra/core": "latest",
    "@mastra/daytona": "latest",
    "@mastra/deployer-sandbox": "latest",
    "@mastra/e2b": "latest",
    "@mastra/vercel": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "mastra": "latest",
    "tsx": "^4.20.6",
    "turbo": "^2.9.12",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "packageExtensions": {
      "@daytonaio/sdk": {
        "dependencies": {
          "tslib": "*"
        }
      }
    },
    "overrides": {
      "@mastra/core": "link:../../packages/core",
      "@mastra/daytona": "link:../../workspaces/daytona",
      "@mastra/deployer-sandbox": "link:../../deployers/sandbox",
      "@mastra/e2b": "link:../../workspaces/e2b",
      "@mastra/vercel": "link:../../workspaces/vercel",
      "mastra": "link:../../packages/cli"
    }
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc"
}
