{
  "id": "daily-standup-digest",
  "description": "Turn raw standup notes into a team-wide markdown digest. Routes to one of two nested stored workflows based on whether the day's notes contain blockers. Seeded at boot from a JSON WorkflowDefinition; survives process restarts via WorkflowDefinitionsStorage.",
  "metadata": {
    "seededFrom": "examples/agent/src/mastra/stored-workflows/daily-standup-digest.json",
    "demonstrates": [
      "declarative tool / agent / mapping / foreach / conditional / workflow entries",
      "three-scope templates (initData, inputData, stepResults)",
      "foreach(agent) round-trip through storage",
      "conditional with declarative predicates",
      "nested stored workflows as first-class step type",
      "Studio picks up a workflow that was never registered via createWorkflow()"
    ]
  },
  "inputSchema": {
    "type": "object",
    "properties": {
      "teamName": { "type": "string" },
      "notes": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "author": { "type": "string" },
            "text": { "type": "string" }
          },
          "required": ["author", "text"]
        }
      }
    },
    "required": ["teamName", "notes"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "markdown": { "type": "string" }
    },
    "required": ["markdown"]
  },
  "graph": [
    {
      "type": "tool",
      "id": "build-normalizer-prompts",
      "toolId": "build-normalizer-prompts",
      "description": "Turns raw standup notes into per-author prompts for the normalizer agent."
    },
    {
      "type": "foreach",
      "step": {
        "type": "agent",
        "id": "normalize-each-note",
        "agentId": "standup-note-normalizer",
        "description": "Normalizes a single standup note into { did, doing, blocked } text."
      },
      "opts": { "concurrency": 3 }
    },
    {
      "type": "mapping",
      "id": "prep-detect-blockers",
      "mapConfig": "{\"normalizedNotesJson\":{\"template\":\"${stepResults.normalize-each-note}\"}}"
    },
    {
      "type": "tool",
      "id": "detect-blockers",
      "toolId": "detect-blockers",
      "description": "Reports whether any normalized standup note contains a real blocker."
    },
    {
      "type": "mapping",
      "id": "prep-sub-workflow-input",
      "mapConfig": "{\"teamName\":{\"template\":\"${initData.teamName}\"},\"normalizedNotesJson\":{\"template\":\"${stepResults.normalize-each-note}\"}}"
    },
    {
      "type": "conditional",
      "steps": [
        {
          "type": "workflow",
          "id": "call-with-escalation",
          "workflowId": "daily-standup-with-escalation",
          "description": "Digest + tech-lead escalation (runs when blockers were detected)."
        },
        {
          "type": "workflow",
          "id": "call-plain-digest",
          "workflowId": "daily-standup-plain",
          "description": "Plain digest (runs when no blockers were detected)."
        }
      ],
      "predicates": [
        { "op": "truthy", "value": { "path": "stepResults.detect-blockers.hasBlockers" } },
        { "op": "falsy", "value": { "path": "stepResults.detect-blockers.hasBlockers" } }
      ]
    }
  ]
}
