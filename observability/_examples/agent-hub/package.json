{
  "name": "@mastra/otel-bridge-agent-hub",
  "version": "0.1.0",
  "description": "Mastra Otel Bridge Agent Hub example",
  "private": true,
  "type": "module",
  "scripts": {
    "tsc": "rm -rf dist && tsc -p tsconfig.build.json",
    "build": "pnpm run tsc",
    "lint": "prettier --check '*/**/*.{js,jsx,ts,tsx}'",
    "lint:fix": "prettier --write '*/**/*.{js,jsx,ts,tsx}'",
    "test": "vitest run",
    "start:test": "OTEL_SERVICE_NAME=agent-hub LOG_PRETTY=true  KNOWN_EXTS=js,ts node -r dotenv/config --loader ts-node/esm --no-warnings=ExperimentalWarning --import=specifier-resolution-node/register --import=./instrumentation-hook.js --import=./src/core/telemetry/init.ts src/server.ts",
    "start": "OTEL_SERVICE_NAME=agent-hub LOG_PRETTY=true  node -r dotenv/config --import=specifier-resolution-node/register --import=./instrumentation-hook.js --import=./dist/core/telemetry/init.js dist/server.js"
  },
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20",
    "pnpm": "^10"
  },
  "dependencies": {
    "@fastify/otel": "0.9.4",
    "@mastra/core": "workspace:*",
    "@mastra/libsql": "workspace:*",
    "@mastra/observability": "workspace:*",
    "@mastra/otel-bridge": "workspace:*",
    "@mastra/server": "workspace:*",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/auto-instrumentations-node": "0.67.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.208.0",
    "@opentelemetry/host-metrics": "0.37.0",
    "@opentelemetry/instrumentation": "0.208.0",
    "@opentelemetry/resources": "2.2.0",
    "@opentelemetry/sdk-node": "0.208.0",
    "@opentelemetry/semantic-conventions": "1.38.0",
    "dotenv": "17.2.0",
    "fastify": "5.6.0",
    "fastify-plugin": "5.0.1",
    "fastify-type-provider-zod": "4.0.2",
    "pino": "9.11.0",
    "specifier-resolution-node": "1.1.4",
    "uri-template": "2.0.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "20.19.7",
    "concurrently": "9.2.1",
    "prettier": "3.6.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.2",
    "vitest": "^2.0.0"
  }
}
