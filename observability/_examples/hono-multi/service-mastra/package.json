{
  "name": "@mastra/hono-multi-service-mastra",
  "version": "0.1.0",
  "description": "Service Mastra - Mastra agent service with OtelBridge for hono-multi example",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start:test": "tsx src/index.ts",
    "start": "node --import=../instrumentation/src/index.ts dist/index.js",
    "build": "tsc",
    "lint": "prettier --check '**/*.{js,ts}'",
    "lint:fix": "prettier --write '**/*.{js,ts}'"
  },
  "dependencies": {
    "@hono/node-server": "^1.15.1",
    "@mastra/core": "workspace:*",
    "@mastra/hono-multi-instrumentation": "workspace:*",
    "@mastra/observability": "workspace:*",
    "@mastra/otel-bridge": "workspace:*",
    "dotenv": "^17.2.0",
    "hono": "^4.10.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "prettier": "^3.6.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2"
  }
}
