{
  "name": "@mastra/voice-google-gemini-live",
  "version": "0.14.4",
  "description": "Mastra Google Gemini Live API integration",
  "type": "module",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown --silent --config tsdown.config.ts",
    "prepack": "tsx ../../scripts/generate-package-docs.ts",
    "build:watch": "tsdown --watch --silent --config tsdown.config.ts",
    "test": "vitest run",
    "test:integration": "vitest run tool-args-integration.test.ts events-integration.test.ts",
    "lint": "eslint ."
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@mastra/schema-compat": "workspace:*",
    "google-auth-library": "^10.9.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@internal/lint": "workspace:*",
    "@internal/test-utils": "workspace:*",
    "@internal/types-builder": "workspace:*",
    "@internal/voice": "workspace:*",
    "@types/node": "22.20.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "eslint": "^10.7.0",
    "tsdown": "0.22.9",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "homepage": "https://mastra.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastra-ai/mastra.git",
    "directory": "voice/google-gemini-live-api"
  },
  "bugs": {
    "url": "https://github.com/mastra-ai/mastra/issues"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
