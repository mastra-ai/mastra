# Kitchen Sink E2E Testing Environment Variables
# Copy this file to .env and fill in your values

# Optional: set to use a real OpenAI model (budget default: gpt-5-nano via live-openai) for kitchen-sink agents when not using fixtures.
# If unset or empty, Mastra uses deterministic mock LLM output (default for CI / Playwright).
OPENAI_API_KEY=

# Optional: verbose Mastra / workflow logs (Pino debug). Does not add OTLP spans — `mastra dev` bundles with externals,
# so pulling in `@mastra/observability` here often breaks resolution from `.mastra/output`; use Studio traces or a non-bundled runner for full exporters.
# KITCHEN_SINK_TRACE=

# WorkOS Auth Configuration (optional - only needed for real auth testing)
# For mocked auth tests, these are not required
WORKOS_API_KEY=your_workos_api_key
WORKOS_CLIENT_ID=your_workos_client_id
WORKOS_REDIRECT_URI=http://localhost:4111/api/auth/sso/callback

# Cookie password for session encryption (minimum 32 characters)
# Generate with: node -e "console.log(crypto.randomUUID() + crypto.randomUUID())"
WORKOS_COOKIE_PASSWORD=your_very_long_cookie_password_minimum_32_chars

# E2E Test Configuration
E2E_PORT=4111
