{
  "name": "@internal/auth",
  "version": "0.0.8",
  "description": "Internal Mastra auth primitives and utilities",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./provider": {
      "import": {
        "types": "./dist/provider/index.d.ts",
        "default": "./dist/provider/index.js"
      },
      "require": {
        "types": "./dist/provider/index.d.ts",
        "default": "./dist/provider/index.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/types/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/types/index.cjs"
      }
    },
    "./session": {
      "import": {
        "types": "./dist/session/index.d.ts",
        "default": "./dist/session/index.js"
      },
      "require": {
        "types": "./dist/session/index.d.ts",
        "default": "./dist/session/index.cjs"
      }
    },
    "./ee": {
      "import": {
        "types": "./dist/ee/index.d.ts",
        "default": "./dist/ee/index.js"
      },
      "require": {
        "types": "./dist/ee/index.d.ts",
        "default": "./dist/ee/index.cjs"
      }
    },
    "./ee/capabilities": {
      "import": {
        "types": "./dist/ee/capabilities.d.ts",
        "default": "./dist/ee/capabilities.js"
      },
      "require": {
        "types": "./dist/ee/capabilities.d.ts",
        "default": "./dist/ee/capabilities.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup --silent --config tsup.config.ts",
    "build:watch": "tsup --watch --silent --config tsup.config.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.build.json"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@internal/core": "workspace:*"
  },
  "devDependencies": {
    "@internal/lint": "workspace:*",
    "@internal/test-utils": "workspace:*",
    "@internal/types-builder": "workspace:*",
    "@types/node": "22.20.1",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "eslint": "^10.7.0",
    "tsup": "^8.5.1",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "hono": "^4.9.4",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "homepage": "https://mastra.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastra-ai/mastra.git",
    "directory": "packages/_internals/auth"
  },
  "bugs": {
    "url": "https://github.com/mastra-ai/mastra/issues"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
