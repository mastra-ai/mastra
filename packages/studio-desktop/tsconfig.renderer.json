{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": false,
    "declarationMap": false,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "noEmit": true,
    "types": [],
    "paths": {
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": ["src/renderer/**/*.ts", "src/renderer/**/*.tsx", "src/shared/**/*.ts"]
}
