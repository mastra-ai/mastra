{
  "extends": "../../tsconfig.node.json",
  "compilerOptions": {
    "composite": true,
    "moduleResolution": "bundler",
    "types": ["node", "vitest"],
    "paths": {
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": [
    "electron.vite.config.ts",
    "vitest.config.ts",
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "src/starter/**/*.ts"
  ]
}
