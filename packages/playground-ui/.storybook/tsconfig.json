{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@/*": ["../src/*"]
    }
  },
  "include": ["../src/**/*", "**/*"],
  "exclude": ["../node_modules", "../dist", "../src/**/__tests__/**", "../src/**/*.test.ts", "../src/**/*.test.tsx"]
}
