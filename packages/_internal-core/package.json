{
  "name": "@internal/core",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Shared storage primitives (constants, types, utilities) for Mastra internal packages",
  "homepage": "https://mastra.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastra-ai/mastra.git",
    "directory": "packages/_internal-core"
  },
  "bugs": {
    "url": "https://github.com/mastra-ai/mastra/issues"
  },
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@internal/lint": "workspace:*",
    "@types/node": "22.19.7",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "eslint": "9.28.0",
    "tsup": "8.5.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
